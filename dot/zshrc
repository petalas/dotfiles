# Clear bunx's per-package temp caches under $TMPDIR. Useful when a cached
# install is corrupt (e.g. partial node_modules from an interrupted download
# causing ERR_MODULE_NOT_FOUND). The (N) qualifier is zsh's NULL_GLOB so
# this is a no-op when nothing matches instead of erroring.
bunx-clean() {
  local tmp="${TMPDIR:-/tmp}"
  rm -rf "${tmp%/}"/bunx-*(N)
}

# ssh with downgraded TERM for hosts that don't have terminal-specific
# terminfo (xterm-ghostty, xterm-kitty, alacritty, etc.). Fixes
# backspace/arrow-key issues. For your own machines, plain `ssh` works.
# To teach a remote host about your real TERM, run `push-terminfo HOST` once.
alias dssh='TERM=xterm-256color ssh'

# push-terminfo HOST: teach a remote host about your local $TERM by copying
# the terminfo entry. Fixes curses apps (bash readline, less, vim, tmux)
# that otherwise get garbage escape sequences for backspace, arrows, etc.
#
# Terminfo is a DB of terminal capabilities keyed by $TERM. Curses apps
# query it at startup. Search order: ~/.terminfo, /etc/terminfo,
# /usr/share/terminfo. If the remote has no entry for your terminal-specific
# $TERM, it falls back to generic defaults that don't match the emulator.
#
# How it works:
#   infocmp -a TERM        decompiles local compiled entry -> source form
#   tic -x -o DIR /dev/stdin  recompiles source back into a binary entry
#                             in DIR (~/.terminfo is user-level, no sudo)
#   -x                     accept extended caps (Ghostty/Kitty define many)
#
# tic and infocmp both ship with ncurses (ncurses-bin on Debian).
push-terminfo() {
  [[ -z "$1" ]] && { echo "usage: push-terminfo HOST"; return 1; }
  local entry term
  term="${TERM:-xterm-ghostty}"
  if ! entry=$(infocmp -a "$term" 2>/dev/null) || [[ -z "$entry" ]]; then
    echo "$term not in local terminfo DB" >&2
    return 1
  fi
  if print -r -- "$entry" | ssh "$1" "tic -x -o \$HOME/.terminfo /dev/stdin"; then
    echo "pushed $term to $1"
  else
    echo "remote tic error" >&2
    return 1
  fi
}

# dssh and push-terminfo both take an SSH host as first arg — reuse ssh's
# completion (which parses ~/.ssh/config + known_hosts).
compdef dssh=ssh 2>/dev/null
compdef push-terminfo=ssh 2>/dev/null

# Sync ~/.config/nvim (fork of kickstart.nvim) with upstream.
#   master  = clean mirror of nvim-lua/kickstart.nvim
#   custom  = your modifications on top
# Fast-forwards master from upstream and pushes it, then rebases custom onto
# master. Stops before pushing custom so you can verify in nvim first — if
# happy, run: git -C ~/.config/nvim push --force-with-lease
sync-nvim() {
  local nvim_dir="$HOME/.config/nvim"
  local upstream_url="https://github.com/nvim-lua/kickstart.nvim.git"

  [[ -d "$nvim_dir/.git" ]] || { echo "not a git repo: $nvim_dir" >&2; return 1; }

  if [[ -n "$(git -C "$nvim_dir" status --porcelain)" ]]; then
    echo "refusing: $nvim_dir has uncommitted changes" >&2
    git -C "$nvim_dir" status -s
    return 1
  fi

  local ahead
  ahead=$(git -C "$nvim_dir" rev-list --count origin/custom..custom 2>/dev/null)
  if (( ahead > 0 )); then
    echo "refusing: custom is $ahead commit(s) ahead of origin/custom — push first" >&2
    return 1
  fi

  if ! git -C "$nvim_dir" remote | grep -qx upstream; then
    echo ":: adding upstream -> $upstream_url"
    git -C "$nvim_dir" remote add upstream "$upstream_url"
  fi

  echo ":: fetching upstream"
  git -C "$nvim_dir" fetch upstream --quiet || return 1

  # Capture current origin/master SHA so we can count new upstream commits
  # later. Use fully-qualified ref because bare "master" is ambiguous once
  # upstream is also a remote with its own master.
  local master_before
  master_before=$(git -C "$nvim_dir" rev-parse refs/remotes/origin/master)

  echo ":: fast-forwarding master from upstream/master"
  # Force-create (or reset) local master to origin/master's tip. Handles the
  # case where master has never been checked out locally.
  git -C "$nvim_dir" checkout -B master origin/master --quiet
  if ! git -C "$nvim_dir" merge --ff-only upstream/master; then
    echo "master diverged from upstream — resolve manually" >&2
    return 1
  fi
  git -C "$nvim_dir" push origin master --quiet

  local gained
  gained=$(git -C "$nvim_dir" rev-list --count "$master_before..master")

  echo ":: rebasing custom onto master"
  git -C "$nvim_dir" checkout custom --quiet
  if git -C "$nvim_dir" rebase master; then
    echo ""
    if (( gained > 0 )); then
      echo "✓ rebased custom onto master ($gained new upstream commits)"
    else
      echo "✓ already up to date"
    fi
    echo "  verify:    nvim"
    echo "  then push: git -C $nvim_dir push --force-with-lease"
  else
    echo ""
    echo "rebase conflict. resolve in $nvim_dir, then:"
    echo "  git -C $nvim_dir rebase --continue"
    echo "  # or abort:"
    echo "  git -C $nvim_dir rebase --abort"
    return 1
  fi
}

