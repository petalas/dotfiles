function upd() {
  local failures=()

  _upd_run() {
    local label="$1"; shift
    local rc=0
    echo "\n\033[1;34m:: $label\033[0m"
    "$@"
    rc=$?
    if (( rc != 0 )); then
      printf '\033[1;31mcommand failed (%d): %s\033[0m\n' "$rc" "$(printf '%q ' "$@")"
      failures+=("$label")
    fi
    return $rc
  }

  _upd_run_bunx_skills() {
    local rc=0
    echo "\n\033[1;34m:: skills\033[0m"
    bunx skills update --global
    rc=$?

    if (( rc != 0 )); then
      echo "skills update failed; clearing bunx temp cache and retrying"
      bunx-clean
      bunx skills update --global
      rc=$?
    fi

    if (( rc != 0 )); then
      printf '\033[1;31mcommand failed (%d): %s\033[0m\n' "$rc" "bunx skills update --global"
      failures+=("skills")
    fi
    return $rc
  }

  # System packages
  if [[ $OSTYPE == linux* ]]; then
    if command -v paru >/dev/null 2>&1; then
      _upd_run "paru" paru -Syu --noconfirm
    elif command -v pacman >/dev/null 2>&1; then
      _upd_run "pacman" sudo pacman -Syu --noconfirm
    elif command -v apt >/dev/null 2>&1; then
      _upd_run "apt update" sudo apt update &&
        _upd_run "apt upgrade" sudo apt upgrade -y &&
        _upd_run "apt autoremove" sudo apt autoremove -y
    fi

    if command -v flatpak >/dev/null 2>&1; then
      _upd_run "flatpak" flatpak update -y
    fi
  fi

  if [[ $OSTYPE == darwin* ]]; then
    if command -v brew >/dev/null 2>&1; then
      _upd_run "brew update" brew update &&
        _upd_run "brew bundle" brew bundle --file="${DOTFILES_DIR:-$HOME/git/dotfiles}/Brewfile" &&
        _upd_run "brew upgrade" brew upgrade
    fi
  fi

  # Language toolchains
  if command -v rustup >/dev/null 2>&1; then
    _upd_run "rustup" rustup update
  fi

  # sdkman (sdk is a shell function, not a binary)
  if [[ -s "${SDKMAN_DIR:-$HOME/.sdkman}/bin/sdkman-init.sh" ]]; then
    # sdk upgrade prompts "Use prescribed default version(s)?" unless
    # sdkman_auto_answer=true; fix idempotently so upd stays non-interactive.
    local sdkman_cfg="${SDKMAN_DIR:-$HOME/.sdkman}/etc/config"
    if [[ -f "$sdkman_cfg" ]] && grep -q '^sdkman_auto_answer=false' "$sdkman_cfg"; then
      sed -i.bak 's/^sdkman_auto_answer=false/sdkman_auto_answer=true/' "$sdkman_cfg" && rm -f "${sdkman_cfg}.bak"
    fi
    _upd_run "sdkman self" sdk selfupdate
    _upd_run "sdkman candidates" sdk update
    _upd_run "sdkman upgrade" sdk upgrade
  fi

  if command -v bun >/dev/null 2>&1; then
    _upd_run "bun" bun upgrade
  fi

  if command -v npm >/dev/null 2>&1; then
    local npm_pkgs=($(npm outdated -g --parseable 2>/dev/null | cut -d: -f4 | sed 's/@[^@]*$//' | grep -v '/\.' | sort -u))
    if (( ${#npm_pkgs[@]} )); then
      _upd_run "npm global" npm update -g "${npm_pkgs[@]}"
    else
      echo "\n\033[1;34m:: npm global\033[0m"
      echo "all packages up to date"
    fi
  fi

  if command -v pnpm >/dev/null 2>&1; then
    # Corepack prompts before downloading a new pnpm tarball; suppress it.
    local pnpm_globals=""
    pnpm_globals=$(env COREPACK_ENABLE_DOWNLOAD_PROMPT=0 pnpm ls -g --depth=0 --parseable 2>/dev/null)
    if [[ -n "$pnpm_globals" ]]; then
      _upd_run "pnpm globals" env COREPACK_ENABLE_DOWNLOAD_PROMPT=0 pnpm update -g --latest
    else
      echo "\n\033[1;34m:: pnpm globals\033[0m"
      echo "no global packages installed"
    fi
  fi

  # Misc tools
  if command -v tldr >/dev/null 2>&1; then
    _upd_run "tldr" tldr -u
  fi

  # neovim config repo (petalas/nvim @ custom) lives at ~/.config/nvim and is
  # cloned, not symlinked, so it must be pulled explicitly. Do this BEFORE the
  # plugin sync so :Lazy operates on current specs — a stale config here is what
  # caused the nvim-treesitter breakage. See docs/LEARNINGS.md.
  local git_sync="${DOTFILES_DIR:-$HOME/git/dotfiles}/lib/git-sync.sh"
  local nvim_cfg="${XDG_CONFIG_HOME:-$HOME/.config}/nvim"
  if [[ -f "$git_sync" && -d "$nvim_cfg/.git" ]]; then
    source "$git_sync"
    _upd_run "nvim config" git_ff "$nvim_cfg"
  fi

  # neovim itself (nightly/HEAD) — run before plugin sync so :Lazy uses the new binary
  local nvim_installer="${DOTFILES_DIR:-$HOME/git/dotfiles}/installers/install_neovim.sh"
  if [[ -f "$nvim_installer" ]]; then
    _upd_run "neovim" bash "$nvim_installer"
  fi

  # neovim plugins (lazy.nvim)
  if command -v nvim >/dev/null 2>&1 && [[ -d "${XDG_DATA_HOME:-$HOME/.local/share}/nvim/lazy/lazy.nvim" ]]; then
    _upd_run "nvim plugins" nvim --headless "+Lazy! sync" +qa
  fi

  if command -v bunx >/dev/null 2>&1; then
    _upd_run_bunx_skills
  fi

  # Summary
  echo ""
  if (( ${#failures[@]} )); then
    echo "\033[1;31m✗ Failed: ${(j:, :)failures}\033[0m"
    unset -f _upd_run _upd_run_bunx_skills
    return 1
  else
    echo "\033[1;32m✓ Everything up to date.\033[0m"
  fi

  unset -f _upd_run _upd_run_bunx_skills
}

# kill anything taking up the specified port, usage example: killport 6060
function killport() {
  sudo lsof -i :$1 | grep LISTEN | awk '{ print $2 }' | xargs kill -9
}

# https://yazi-rs.github.io/docs/quick-start
# yazi wrapper that provides the ability to change the current working directory when exiting Yazi.
function y() {
    local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
    yazi "$@" --cwd-file="$tmp"
    if cwd="$(command cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
        builtin cd -- "$cwd"
    fi
    rm -f -- "$tmp"
}

