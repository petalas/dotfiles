#!/usr/bin/env bash
# Pre-commit: shellcheck staged *.sh files.
# No-op if shellcheck isn't installed (brew install shellcheck).
#
# Excluded codes:
#   SC2034 — unused color vars (ceremonial "red/green/yellow" at top of installers)
#   SC1090 — can't follow non-constant source (intentional in source_installers.sh)

if ! command -v shellcheck >/dev/null 2>&1; then
	echo "[pre-commit] shellcheck not installed — skipping (brew install shellcheck)"
	exit 0
fi

mapfile -t staged < <(git diff --cached --name-only --diff-filter=ACM | grep -E '\.sh$')
[[ ${#staged[@]} -eq 0 ]] && exit 0

echo "[pre-commit] shellcheck: ${staged[*]}"
shellcheck --severity=warning --exclude=SC2034,SC1090 "${staged[@]}"
